/* ---- home ---- */
function renderHome(){
  const hasFarm=!!currentFarmId;
  document.getElementById('no-farm-msg').style.display=hasFarm?'none':'block';
  document.getElementById('home-content').style.display=hasFarm?'block':'none';
  if(!hasFarm)return;

  const ss=silos();

  // 各サイロについて「最新訪問記録の在庫量」があればそちらを使う
  function effectiveStock(s){
    const latest=visits().filter(v=>v.siloId===s.id).sort((a,b)=>b.date.localeCompare(a.date))[0];
    if(latest&&latest.netAct!=null){
      return{netDM:latest.netDM||0, netAct:latest.netAct||0, fromVisit:true, visitDate:latest.date, visitDays:latest.days};
    }
    return{netDM:s.netDM||0, netAct:s.netAct||0, fromVisit:false};
  }

  const byType={GS1:{dm:0,act:0},GS2:{dm:0,act:0},GS3:{dm:0,act:0},sorghum:{dm:0,act:0},DCS:{dm:0,act:0}};
  ss.forEach(s=>{
    const st=effectiveStock(s);
    if(byType[s.silage]){byType[s.silage].dm+=st.netDM;byType[s.silage].act+=st.netAct;}
  });
  const gsDM=byType.GS1.dm+byType.GS2.dm+byType.GS3.dm+byType.sorghum.dm;
  const gsAct=byType.GS1.act+byType.GS2.act+byType.GS3.act+byType.sorghum.act;
  const dcsDM=byType.DCS.dm,dcsAct=byType.DCS.act;
  const gsDaily=getDailyFromLVGroup('gs'),dcsDaily=getDailyFromLVGroup('dcs');
  const gsResult=calcDaysRemaining('GS1',gsAct);
  const dcsResult=calcDaysRemaining('DCS',dcsAct);

  function forecastHTML(result,label,daily,hasData){
    if(!hasData||daily<=0)return`<div class="forecast-banner ok" style="opacity:.5"><div class="fb-right"><div class="fb-label">${label} 残り日数</div><div class="fb-sub">給与量を「給与設定」から入力してください</div></div></div>`;
    const d=result.days;
    const cls=d>=60?'ok':d>=30?'warn':'danger';
    const untilStr=result.endDate?result.endDate.toLocaleDateString('ja-JP',{month:'long',day:'numeric'}):'';
    return`<div class="forecast-banner ${cls}"><div class="fb-days ${cls}">${d}</div><div class="fb-right">
      <div class="fb-label">${label} 残り日数（月別計画ベース）</div>
      <div class="fb-sub">${untilStr}ごろまで / 今月の日消費 ${fmtN(daily)}kg</div></div></div>`;
  }
  document.getElementById('forecast-gs').innerHTML=forecastHTML(gsResult,'グラスサイレージ合計',gsDaily,gsAct>0);
  document.getElementById('forecast-dcs').innerHTML=forecastHTML(dcsResult,'デントコーンサイレージ',dcsDaily,dcsAct>0);

  const spDefs=[{key:'GS1',label:'GS1（1番草）',cls:'gs1'},{key:'GS2',label:'GS2（2番草）',cls:'gs2'},
    {key:'GS3',label:'GS3（3番草）',cls:'gs3'},{key:'sorghum',label:'ソルガム',cls:'sorghum'},
    {key:'DCS',label:'DCS（デントコーン）',cls:'corn',full:true}];
  let scHTML='<div class="species-grid">';
  spDefs.forEach(sp=>{const d=byType[sp.key];
    scHTML+=`<div class="sp-card${sp.full?' full':''}"><div class="sp-head ${sp.cls}">${sp.label}</div>
      <div class="sp-body"><div class="sp-row"><span class="sl">乾物</span><span class="sv hi">${fmt(d.dm/1000,2)} t DM</span></div>
      <div class="sp-row"><span class="sl">現物</span><span class="sv">${fmt(d.act/1000,2)} t</span></div></div></div>`;
  });
  scHTML+=`</div><div style="display:flex;justify-content:space-between;padding:6px 4px 4px;font-size:12px;color:var(--text2)">
    <span>GS合計</span><span style="font-weight:700;color:var(--teal)">${fmt(gsDM/1000,2)} t DM</span></div>
  <div style="font-size:11px;color:var(--text3);padding:0 4px 12px">※訪問記録がある場合はその在庫量を反映</div>`;
  document.getElementById('species-cards').innerHTML=scHTML;

  let html='';
  ['banker','stack','wrap'].forEach(tp=>{
    const m=TYPE_META[tp],group=ss.filter(s=>s.type===tp);
    const totDM=group.reduce((a,s)=>a+effectiveStock(s).netDM,0);
    const totAct=group.reduce((a,s)=>a+effectiveStock(s).netAct,0);
    html+=`<div class="storage-section"><div class="storage-header ${m.cls}">
      <span class="storage-title ${m.cls}">${m.label}</span><span class="storage-count ${m.cls}">${group.length}基</span></div>
      <div class="storage-totals">
        <div class="st-cell"><div class="st-cell-lbl">合計乾物</div><div class="st-cell-val hi">${fmt(totDM/1000,2)} t DM</div></div>
        <div class="st-cell"><div class="st-cell-lbl">合計現物</div><div class="st-cell-val">${fmt(totAct/1000,2)} t</div></div>
      </div>`;
    if(!group.length)html+=`<div class="empty-sub">まだ登録がありません</div>`;
    else group.slice().reverse().forEach(s=>{
      const st=effectiveStock(s);
      const visitBadge=st.fromVisit
        ?`<span style="font-size:10px;background:var(--teal-light);color:var(--teal);padding:1px 6px;border-radius:8px;font-weight:700">📋 ${st.visitDate}</span>`
        :`<span style="font-size:10px;color:var(--text3)">登録値</span>`;
      html+=`<div class="silo-item"><div class="silo-item-head">
        <span class="silo-item-name">${s.name}</span>
        <span class="badge ${isGS(s.silage)?'b-grass':'b-corn'}">${s.silage}</span>
        <span class="silo-item-sub">DM ${s.dm||'—'}%</span></div>
        <div class="silo-item-vals">
          <div class="siv"><span>乾物</span><strong>${fmt(st.netDM/1000,2)} t DM</strong></div>
          <div class="siv"><span>現物</span><strong>${fmt(st.netAct/1000,2)} t</strong></div>
          ${s.grass?`<div class="siv"><span>草種</span><strong>${grassLabel(s.grass)}</strong></div>`:''}
          ${s.opened?`<div class="siv"><span>開封日</span><strong>${s.opened}</strong></div>`:''}
        </div>
        <div style="display:flex;align-items:center;gap:6px;margin-top:6px;padding-top:6px;border-top:0.5px solid var(--border);font-size:11px">
          <span style="color:var(--text3)">在庫ソース:</span>${visitBadge}
          ${st.fromVisit&&st.visitDays!=null?`<span style="margin-left:auto;color:var(--teal);font-weight:700">残り${Math.floor(st.visitDays)}日</span>`:''}
        </div>
      </div>`;
    });
    html+=`</div>`;
  });
  document.getElementById('home-storage').innerHTML=html;
}

const GRASS_LABEL={orchard:'オーチャード',timothy:'チモシー',orch_tim:'オーチャード＋チモシー',orch_leg:'オーチャード＋マメ科',tim_leg:'チモシー＋マメ科'};
function grassLabel(v){return GRASS_LABEL[v]||'';}

/* ---- list ---- */
function renderList(){
  const el=document.getElementById('list-silos'),ss=silos();
  if(!ss.length){el.innerHTML='<div style="text-align:center;padding:3rem 1rem;color:var(--text3);font-size:13px">登録済みの貯蔵庫がありません</div>';return;}
  el.innerHTML=[...ss].reverse().map(s=>{
    const grassRow=s.grass?`<div class="siv"><span>草種</span><strong>${grassLabel(s.grass)}</strong></div>`:'';
    const seededRow=s.seeded?`<div class="siv"><span>播種日</span><strong>${s.seeded}</strong></div>`:'';
    const harvestRow=s.harvest?`<div class="siv"><span>刈り取り日</span><strong>${s.harvest}</strong></div>`:'';
    const growRow=s.growDays!=null?`<div class="siv"><span>生育日数</span><strong>${s.growDays}日</strong></div>`:'';
    const openedRow=s.opened?`<div class="siv"><span>開封日</span><strong>${s.opened}</strong></div>`:'';
    const storeRow=s.storeDays!=null?`<div class="siv"><span>貯蔵日数</span><strong>${s.storeDays}日</strong></div>`:'';
    const varietyRow=s.varietyDays?`<div class="siv"><span>品種生育日数</span><strong>${s.varietyDays}日</strong></div>`:'';
    const densityRow=s.density?`<div class="siv"><span>密度</span><strong>${s.density} kgDM/m³</strong></div>`:'';
    const extraRow=s.type==='banker'?`<div class="siv"><span>パネル</span><strong>${s.panels}枚 × ${s.plen}m</strong></div>`
      :s.type==='stack'?`<div class="siv"><span>長さ</span><strong>${s.len}m</strong></div>`
      :`<div class="siv"><span>個数</span><strong>${s.count}個 × ${s.wt}kg</strong></div>`;
    return`<div class="silo-item" style="margin-bottom:10px">
      <div class="silo-item-head"><span class="silo-item-name">${s.name}</span>
        <span class="badge ${isGS(s.silage)?'b-grass':'b-corn'}">${s.silage}</span>
        <span style="font-size:11px;color:var(--text3);margin-left:auto">${TYPE_META[s.type].label}</span></div>
      <div class="silo-item-vals" style="margin-bottom:10px">
        <div class="siv"><span>乾物在庫</span><strong>${fmt((s.netDM||0)/1000,2)} t DM</strong></div>
        <div class="siv"><span>現物在庫</span><strong>${fmt((s.netAct||0)/1000,2)} t</strong></div>
        <div class="siv"><span>DM%</span><strong>${s.dm||'—'}%</strong></div>
        <div class="siv"><span>ロス率</span><strong>${s.loss||0}%</strong></div>
        ${grassRow}${varietyRow}${seededRow}${harvestRow}${growRow}${openedRow}${storeRow}${densityRow}${extraRow}
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button class="btn btn-sm" style="flex:0" onclick="openEdit(${s.id})"><i class="ti ti-edit"></i> 編集</button>
        <button class="btn btn-danger btn-sm" style="flex:0" onclick="deleteSilo(${s.id})"><i class="ti ti-trash"></i> 削除</button>
      </div></div>`;
  }).join('');
}

/* ---- edit ---- */
let editId=null;
function openEdit(id){
  const s=silos().find(x=>x.id===id);if(!s)return;
  editId=id;
  document.getElementById('edit-title').textContent=`編集：${s.name}`;
  document.getElementById('edit-calc-result').style.display='none';
  document.getElementById('edit-msg').textContent='';
  const qOpts=`<option value="">手動入力</option><option value="260">DCS 非常に良い（260）</option><option value="240">DCS 良い/GS 非常に良い（240）</option><option value="220">DCS 普通/GS 良い（220）</option><option value="200">DCS 悪い/GS 普通（200）</option><option value="180">DCS かなり悪い/GS 悪い（180）</option><option value="150">GS かなり悪い（150）</option>`;
  let body=`<div class="form-block"><label>名称</label><input id="ed-name" type="text" value="${s.name}"></div>
    <div class="form-block"><label>サイレージ種類</label><select id="ed-silage">
      <option value="GS1"${s.silage==='GS1'?' selected':''}>GS1</option><option value="GS2"${s.silage==='GS2'?' selected':''}>GS2</option>
      <option value="GS3"${s.silage==='GS3'?' selected':''}>GS3</option><option value="DCS"${s.silage==='DCS'?' selected':''}>DCS</option>
      <option value="sorghum"${s.silage==='sorghum'?' selected':''}>ソルガム</option></select></div>
    <div class="form-block"><label>草種</label><select id="ed-grass">
      <option value=""${!s.grass?' selected':''}>— 選択してください —</option>
      <option value="orchard"${s.grass==='orchard'?' selected':''}>オーチャード</option>
      <option value="timothy"${s.grass==='timothy'?' selected':''}>チモシー</option>
      <option value="orch_tim"${s.grass==='orch_tim'?' selected':''}>オーチャード＋チモシー</option>
      <option value="orch_leg"${s.grass==='orch_leg'?' selected':''}>オーチャード＋マメ科</option>
      <option value="tim_leg"${s.grass==='tim_leg'?' selected':''}>チモシー＋マメ科</option>
    </select></div>
    <div class="form-row-2">
      <div class="form-block"><label>播種日</label><input type="date" id="ed-seeded" value="${s.seeded||''}" onchange="calcDays('ed')"></div>
      <div class="form-block"><label>刈り取り日</label><input type="date" id="ed-harvest" value="${s.harvest||''}" onchange="calcDays('ed')"></div>
    </div>
    <div class="form-block"><label>生育日数</label>
      <div id="ed-growdays" style="padding:10px 12px;background:var(--bg2);border-radius:var(--radius);font-size:14px;font-weight:700;color:var(--teal)">${s.growDays!=null?s.growDays+'日':'—'}</div>
    </div>
    ${s.silage==='DCS'?`<div class="form-block"><label>品種の生育日数（日）</label><input type="number" id="ed-variety-days" inputmode="numeric" value="${s.varietyDays||''}"></div>`:''}
    <div class="form-row-2">
      <div class="form-block"><label>開封日</label><input type="date" id="ed-opened" value="${s.opened||''}" onchange="calcDays('ed')"></div>
      <div class="form-block"><label>貯蔵日数</label>
        <div id="ed-storedays" style="padding:10px 12px;background:var(--bg2);border-radius:var(--radius);font-size:14px;font-weight:700;color:var(--purple-text)">${s.storeDays!=null?s.storeDays+'日':'—'}</div>
      </div>
    </div>`;
  if(s.type==='banker')body+=`<div class="form-row-2"><div class="form-block"><label>横 (m)</label><input type="number" id="ed-width" inputmode="decimal" value="${s.width||''}"></div>
    <div class="form-block"><label>高さ (m)</label><input type="number" id="ed-h" inputmode="decimal" value="${s.h||''}"></div></div>
    <div class="form-row-2"><div class="form-block"><label>1パネル長さ (m)</label><input type="number" id="ed-plen" inputmode="decimal" value="${s.plen||''}"></div>
    <div class="form-block"><label>総パネル枚数</label><input type="number" id="ed-panels" inputmode="numeric" value="${s.panels||''}"></div></div>`;
  else if(s.type==='stack')body+=`<div class="form-row-2"><div class="form-block"><label>上面幅 (m)</label><input type="number" id="ed-tw" inputmode="decimal" value="${s.tw||''}"></div>
    <div class="form-block"><label>底面幅 (m)</label><input type="number" id="ed-bw" inputmode="decimal" value="${s.bw||''}"></div></div>
    <div class="form-row-2"><div class="form-block"><label>高さ (m)</label><input type="number" id="ed-h" inputmode="decimal" value="${s.h||''}"></div>
    <div class="form-block"><label>総長さ (m)</label><input type="number" id="ed-len" inputmode="decimal" value="${s.len||''}"></div></div>
    <div class="form-block"><label>形状係数</label><select id="ed-coef"><option value="0.75"${s.coef==0.75?' selected':''}>0.75</option><option value="0.77"${s.coef==0.77?' selected':''}>0.77</option><option value="0.80"${(!s.coef||s.coef==0.80)?' selected':''}>0.80</option></select></div>`;
  else body+=`<div class="form-row-2"><div class="form-block"><label>1個あたり重量 (kg)</label><input type="number" id="ed-wt" inputmode="numeric" value="${s.wt||''}"></div>
    <div class="form-block"><label>総個数</label><input type="number" id="ed-count" inputmode="numeric" value="${s.count||''}"></div></div>`;
  if(s.type!=='wrap')body+=`<div class="form-block"><label>充填品質プリセット</label>
    <select id="ed-quality" onchange="document.getElementById('ed-density').value=this.value||document.getElementById('ed-density').value">${qOpts}</select></div>
    <div class="form-block"><label>密度 (kgDM/m³)</label><input type="number" id="ed-density" inputmode="numeric" value="${s.density||''}"></div>`;
  body+=`<div class="form-row-2"><div class="form-block"><label>DM%（乾物率）</label><input type="number" id="ed-dm" inputmode="decimal" value="${s.dm||''}"></div>
    <div class="form-block"><label>ロス率 (%)</label><input type="number" id="ed-loss" inputmode="decimal" value="${s.loss||''}"></div></div>`;
  document.getElementById('edit-form-body').innerHTML=body;
  document.getElementById('edit-sheet').classList.add('open');
}
function closeEdit(){document.getElementById('edit-sheet').classList.remove('open');editId=null;}
function calcEditValues(){
  const ss=silos(),s=ss.find(x=>x.id===editId);if(!s)return null;
  const dm=+document.getElementById('ed-dm').value||0,loss=+document.getElementById('ed-loss').value||0;
  if(s.type==='banker'){
    const w=+document.getElementById('ed-width').value||0,h=+document.getElementById('ed-h').value||0;
    const plen=+document.getElementById('ed-plen').value||0,panels=+document.getElementById('ed-panels').value||0;
    const den=+document.getElementById('ed-density').value||0,vol=plen*panels*w*h,dmKg=vol*den,actKg=dm>0?dmKg/(dm/100):0;
    return{vol,netDM:dmKg*(1-loss/100),netAct:actKg*(1-loss/100),dmKg,actKg,den,w,h,plen,panels,dm,loss,type:'banker'};
  }else if(s.type==='stack'){
    const tw=+document.getElementById('ed-tw').value||0,bw=+document.getElementById('ed-bw').value||0;
    const h=+document.getElementById('ed-h').value||0,len=+document.getElementById('ed-len').value||0;
    const coef=+document.getElementById('ed-coef').value||0.8,den=+document.getElementById('ed-density').value||0;
    const vol=(tw+bw)/2*h*len*coef,dmKg=vol*den,actKg=dm>0?dmKg/(dm/100):0;
    return{vol,netDM:dmKg*(1-loss/100),netAct:actKg*(1-loss/100),dmKg,actKg,den,tw,bw,h,len,coef,dm,loss,type:'stack'};
  }else{
    const wt=+document.getElementById('ed-wt').value||0,cnt=+document.getElementById('ed-count').value||0;
    const actKg=wt*cnt,dmKg=actKg*(dm/100);
    return{netDM:dmKg*(1-loss/100),netAct:actKg*(1-loss/100),wt,cnt,dm,loss,type:'wrap'};
  }
}
function calcEdit(){
  const r=calcEditValues();if(!r)return;
  const el=document.getElementById('edit-calc-result');el.style.display='block';
  if(r.type==='wrap')el.innerHTML=`<div class="res-row"><span class="rl">現物（ロス差引）</span><span class="rv hi">${fmt(r.netAct/1000,2)} t</span></div>
    <div class="res-row"><span class="rl">乾物（ロス差引）</span><span class="rv hi">${fmt(r.netDM/1000,2)} t DM</span></div>`;
  else el.innerHTML=`<div class="res-row"><span class="rl">容積</span><span class="rv">${fmt(r.vol,1)} m³</span></div>
    <div class="res-row"><span class="rl">現物（ロス差引）</span><span class="rv hi">${fmt(r.netAct/1000,2)} t</span></div>
    <div class="res-row"><span class="rl">乾物（ロス差引）</span><span class="rv hi">${fmt(r.netDM/1000,2)} t DM</span></div>`;
}
function saveEdit(){
  calcEdit();const r=calcEditValues();if(!r)return;
  const idx=silos().findIndex(x=>x.id===editId);if(idx<0)return;
  const s=farmData().silos[farmData().silos.findIndex(x=>x.id===editId)];
  s.name=document.getElementById('ed-name').value||s.name;
  s.silage=document.getElementById('ed-silage').value;
  s.grass=document.getElementById('ed-grass').value;
  s.seeded=document.getElementById('ed-seeded')?.value||'';
  s.harvest=document.getElementById('ed-harvest')?.value||'';
  s.opened=document.getElementById('ed-opened')?.value||'';
  s.varietyDays=document.getElementById('ed-variety-days')?.value||'';
  s.growDays=diffDays(s.seeded,s.harvest);
  s.storeDays=diffDays(s.harvest,s.opened);
  s.dm=r.dm;s.loss=r.loss;s.netDM=r.netDM;s.netAct=r.netAct;
  if(r.type==='banker'){s.width=r.w;s.h=r.h;s.plen=r.plen;s.panels=r.panels;s.density=r.den;}
  else if(r.type==='stack'){s.tw=r.tw;s.bw=r.bw;s.h=r.h;s.len=r.len;s.coef=r.coef;s.density=r.den;}
  else{s.wt=r.wt;s.count=r.cnt;}
  persist();document.getElementById('edit-msg').textContent='保存しました ✓';
  setTimeout(()=>{closeEdit();renderList();renderHome();},900);
}

/* ---- farm edit ---- */
let editFarmId=null;
function openFarmEdit(id){
  const f=farms.find(x=>x.id===id);if(!f)return;
  editFarmId=id;
  document.getElementById('fe-name').value=f.name;
  document.getElementById('fe-note').value=f.note||'';
  document.getElementById('fe-msg').textContent='';
  document.getElementById('farm-edit-sheet').classList.add('open');
}
function closeFarmEdit(){document.getElementById('farm-edit-sheet').classList.remove('open');editFarmId=null;}
function saveFarmEdit(){
  const name=document.getElementById('fe-name').value.trim();
  if(!name){document.getElementById('fe-msg').textContent='農場名を入力してください';return;}
  const f=farms.find(x=>x.id===editFarmId);if(!f)return;
  f.name=name;f.note=document.getElementById('fe-note').value.trim();
  persist();
  if(currentFarmId===editFarmId)document.getElementById('current-farm-name').innerHTML=`<i class="ti ti-building-farm"></i> ${f.name}`;
  document.getElementById('fe-msg').textContent='保存しました ✓';
  setTimeout(()=>{closeFarmEdit();renderFarmList();},800);
}


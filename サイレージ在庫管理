function calcVisitStock(s){
  if(s.type==='banker'){
    const used=+document.getElementById('vis-panels-used').value||0,rem=Math.max(0,(s.panels||0)-used);
    const vol=rem*(s.plen||0)*(s.width||0)*(s.h||0),dmKg=vol*(s.density||0),actKg=s.dm>0?dmKg/(s.dm/100):0;
    return{remPanels:rem,usedPanels:used,vol,netDM:dmKg*(1-(s.loss||0)/100),netAct:actKg*(1-(s.loss||0)/100),type:'banker'};
  }else if(s.type==='stack'){
    const used=+document.getElementById('vis-stack-used').value||0,rem=Math.max(0,(s.len||0)-used);
    const vol=(s.tw+s.bw)/2*(s.h||0)*rem*(s.coef||0.8),dmKg=vol*(s.density||0),actKg=s.dm>0?dmKg/(s.dm/100):0;
    return{remLen:rem,usedLen:used,vol,netDM:dmKg*(1-(s.loss||0)/100),netAct:actKg*(1-(s.loss||0)/100),type:'stack'};
  }else{
    const used=+document.getElementById('vis-wrap-used').value||0,rem=Math.max(0,(s.count||0)-used);
    const actKg=rem*(s.wt||0),dmKg=actKg*((s.dm||0)/100);
    return{remCount:rem,usedCount:used,netDM:dmKg*(1-(s.loss||0)/100),netAct:actKg*(1-(s.loss||0)/100),type:'wrap'};
  }
}
function calcVisit(){
  const id=+document.getElementById('vis-silo').value;

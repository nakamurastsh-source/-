<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="サイレージ">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0F6E56">
<link rel="manifest" href="manifest.json">
<!-- Apple touch icons (inline SVG converted to data URI via JS below) -->
<link rel="apple-touch-icon" href="icon-192.png">
<title>サイレージ在庫管理</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.47.0/tabler-icons.min.css">
<style>
:root{
  --bg:#fff;--bg2:#f5f5f5;--bg3:#ebebeb;
  --text:#111;--text2:#555;--text3:#999;
  --border:rgba(0,0,0,0.11);--border2:rgba(0,0,0,0.2);
  --green-bg:#EAF3DE;--green-text:#27500A;
  --blue-bg:#E6F1FB;--blue-text:#0C447C;
  --purple-bg:#EEEDFE;--purple-text:#3C3489;
  --amber-bg:#FAEEDA;--amber-text:#633806;
  --pink-bg:#FBEAF0;--pink-text:#72243E;
  --red-bg:#FCEBEB;--red-text:#A32D2D;
  --warn-bg:#FAEEDA;--warn-text:#854F0B;
  --teal:#0F6E56;--teal-light:#E1F5EE;
  --radius:8px;--radius-lg:12px;
}
@media(prefers-color-scheme:dark){:root{
  --bg:#1a1a1a;--bg2:#242424;--bg3:#2e2e2e;
  --text:#f0f0f0;--text2:#aaa;--text3:#666;
  --border:rgba(255,255,255,0.1);--border2:rgba(255,255,255,0.2);
  --green-bg:#1a2e10;--green-text:#9FE1CB;
  --blue-bg:#0d2240;--blue-text:#85B7EB;
  --purple-bg:#1a1840;--purple-text:#AFA9EC;
  --amber-bg:#2e1f08;--amber-text:#FAC775;
  --pink-bg:#2e1020;--pink-text:#ED93B1;
  --red-bg:#3a1010;--red-text:#F09595;
  --warn-bg:#2e1f08;--warn-text:#FAC775;
  --teal:#5DCAA5;--teal-light:#04342C;
}}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,BlinkMacSystemFont,'Hiragino Sans','Hiragino Kaku Gothic ProN',sans-serif;background:var(--bg);color:var(--text);font-size:15px}
.app{max-width:390px;margin:0 auto;padding:0 0 72px;min-height:100vh}

/* top bar */
.top-bar{display:flex;align-items:center;justify-content:space-between;padding:12px 16px 10px;border-bottom:0.5px solid var(--border);position:sticky;top:0;background:var(--bg);z-index:20}
.top-bar-left{display:flex;flex-direction:column;gap:1px}
.top-bar-title{font-size:15px;font-weight:700;color:var(--text)}
.farm-switcher{display:flex;align-items:center;gap:6px;cursor:pointer}
.farm-name{font-size:13px;font-weight:700;color:var(--teal)}
.farm-name i{font-size:14px;vertical-align:-2px}
.top-bar-date{font-size:11px;color:var(--text3)}

/* farm select screen */
.farm-screen{padding:16px}
.farm-card{border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:14px 16px;margin-bottom:10px;display:flex;align-items:center;gap:12px;cursor:pointer;background:var(--bg)}
.farm-card:active{background:var(--bg2)}
.farm-card.selected{border-color:var(--teal);border-width:1.5px}
.farm-icon{width:40px;height:40px;border-radius:50%;background:var(--teal-light);display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--teal);flex-shrink:0}
.farm-info{flex:1;min-width:0}
.farm-info-name{font-size:14px;font-weight:700;color:var(--text)}
.farm-info-sub{font-size:11px;color:var(--text3);margin-top:2px}
.farm-add-btn{border:0.5px dashed var(--border2);border-radius:var(--radius-lg);padding:14px;text-align:center;font-size:14px;color:var(--text2);cursor:pointer;margin-bottom:10px}

/* pages */
.page{display:none;padding:12px 16px}
.page.active{display:block}
.sec-lbl{font-size:11px;font-weight:700;color:var(--text2);letter-spacing:.06em;text-transform:uppercase;margin:16px 0 8px}
.sec-lbl:first-child{margin-top:4px}

/* forecast */
.forecast-banner{border-radius:var(--radius-lg);padding:14px 16px;margin-bottom:10px;display:flex;align-items:center;gap:12px}
.forecast-banner.ok{background:var(--teal-light)}
.forecast-banner.warn{background:var(--warn-bg)}
.forecast-banner.danger{background:var(--red-bg)}
.fb-days{font-size:36px;font-weight:700;line-height:1}
.fb-days.ok{color:var(--teal)}.fb-days.warn{color:var(--warn-text)}.fb-days.danger{color:var(--red-text)}
.fb-label{font-size:12px;color:var(--text2);margin-bottom:2px}
.fb-sub{font-size:11px;color:var(--text3)}

/* species */
.species-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.sp-card{border:0.5px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
.sp-card.full{grid-column:1/-1}
.sp-head{padding:8px 12px;font-size:12px;font-weight:700}
.sp-head.gs1{background:#EAF3DE;color:#27500A}
.sp-head.gs2{background:#C0DD97;color:#27500A}
.sp-head.gs3{background:#97C459;color:#173404}
.sp-head.sorghum{background:#D3D1C7;color:#2C2C2A}
.sp-head.corn{background:var(--blue-bg);color:var(--blue-text)}
.sp-body{padding:10px 12px}
.sp-row{display:flex;justify-content:space-between;font-size:12px;padding:2px 0}
.sp-row .sl{color:var(--text2)}.sp-row .sv{font-weight:700;color:var(--text)}.sp-row .sv.hi{color:var(--teal)}

/* storage */
.storage-section{margin-bottom:12px}
.storage-header{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:var(--radius-lg);margin-bottom:6px}
.storage-header.banker{background:var(--purple-bg)}.storage-header.stack{background:var(--amber-bg)}.storage-header.wrap{background:var(--pink-bg)}
.storage-title{font-size:13px;font-weight:700}
.storage-title.banker{color:var(--purple-text)}.storage-title.stack{color:var(--amber-text)}.storage-title.wrap{color:var(--pink-text)}
.storage-count{font-size:11px;margin-left:auto;padding:2px 9px;border-radius:10px;font-weight:700}
.storage-count.banker{background:var(--purple-bg);color:var(--purple-text);border:0.5px solid var(--purple-text)}
.storage-count.stack{background:var(--amber-bg);color:var(--amber-text);border:0.5px solid var(--amber-text)}
.storage-count.wrap{background:var(--pink-bg);color:var(--pink-text);border:0.5px solid var(--pink-text)}
.storage-totals{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px}
.st-cell{background:var(--bg2);border-radius:var(--radius);padding:10px 12px}
.st-cell-lbl{font-size:11px;color:var(--text2);margin-bottom:2px}
.st-cell-val{font-size:15px;font-weight:700;color:var(--text)}.st-cell-val.hi{color:var(--teal)}

/* silo items */
.silo-item{border:0.5px solid var(--border);border-radius:var(--radius);padding:10px 12px;margin-bottom:6px;background:var(--bg)}
.silo-item-head{display:flex;align-items:center;gap:6px;margin-bottom:6px;flex-wrap:wrap}
.silo-item-name{font-size:13px;font-weight:700;color:var(--text)}
.silo-item-sub{font-size:11px;color:var(--text3);margin-left:auto}
.badge{display:inline-block;font-size:11px;padding:2px 7px;border-radius:10px;font-weight:700}
.b-grass{background:var(--green-bg);color:var(--green-text)}.b-corn{background:var(--blue-bg);color:var(--blue-text)}
.silo-item-vals{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.siv{font-size:11px;color:var(--text2)}
.siv strong{display:block;font-size:13px;font-weight:700;color:var(--text);margin-top:1px}
.empty-sub{text-align:center;padding:.875rem;color:var(--text3);font-size:12px;border:0.5px dashed var(--border2);border-radius:var(--radius);margin-bottom:8px}

/* forms */
.seg{display:flex;border:0.5px solid var(--border2);border-radius:var(--radius);overflow:hidden;margin-bottom:16px}
.seg-btn{flex:1;padding:11px 4px;border:none;background:none;cursor:pointer;font-size:13px;color:var(--text2);text-align:center;font-weight:500}
.seg-btn.active{background:var(--text);color:var(--bg);font-weight:700}
.form-block{margin-bottom:12px}
.form-block label{display:block;font-size:12px;color:var(--text2);margin-bottom:5px;font-weight:600}
input,select,textarea{font-size:16px;border:0.5px solid var(--border2);border-radius:var(--radius);padding:11px 12px;background:var(--bg);color:var(--text);width:100%;-webkit-appearance:none;appearance:none;font-family:inherit}
input:focus,select:focus{outline:2px solid var(--teal);outline-offset:1px}
.form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.form-row-2 .form-block{margin-bottom:0}
.result-box{background:var(--bg2);border-radius:var(--radius);padding:12px;margin:12px 0}
.res-row{display:flex;justify-content:space-between;align-items:baseline;padding:3px 0;font-size:13px}
.res-row .rl{color:var(--text2)}.res-row .rv{font-weight:700;color:var(--text)}.res-row .rv.hi{font-size:15px;color:var(--teal)}
.divider{border:none;border-top:0.5px solid var(--border);margin:6px 0}
.btn-row{display:flex;gap:8px;margin-top:4px}
.btn{padding:13px 16px;border-radius:var(--radius);font-size:14px;cursor:pointer;border:0.5px solid var(--border2);background:var(--bg);color:var(--text);flex:1;text-align:center;font-weight:600}
.btn-primary{background:var(--text);color:var(--bg);border-color:var(--text)}
.btn-danger{color:#c0392b;border-color:#c0392b;flex:0;padding:13px 14px}
.btn-sm{padding:8px 12px;font-size:13px}
.success-msg{font-size:12px;color:var(--teal);text-align:center;padding:6px 0;font-weight:600}

/* livestock */
.livestock-card{border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:14px;margin-bottom:12px;background:var(--bg)}
.lc-title{font-size:13px;font-weight:700;margin-bottom:10px}

/* visit */
.visit-card{border:0.5px solid var(--border);border-radius:var(--radius-lg);padding:12px 14px;margin-bottom:8px;background:var(--bg)}
.visit-date{font-size:13px;font-weight:700;color:var(--text);margin-bottom:6px;display:flex;align-items:center;gap:8px}
.visit-rows{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.vr{font-size:11px;color:var(--text2)}
.vr strong{display:block;font-size:13px;font-weight:700;color:var(--text);margin-top:1px}
.visit-note{font-size:12px;color:var(--text3);margin-top:6px;padding-top:6px;border-top:0.5px solid var(--border)}

/* modal sheet */
.sheet-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:100;align-items:flex-end;justify-content:center}
.sheet-overlay.open{display:flex}
.sheet{background:var(--bg);border-radius:var(--radius-lg) var(--radius-lg) 0 0;width:100%;max-width:390px;padding:20px 16px 36px;max-height:88vh;overflow-y:auto}
.sheet-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.sheet-title{font-size:15px;font-weight:700;color:var(--text)}
.sheet-close{border:none;background:none;font-size:22px;color:var(--text2);cursor:pointer;padding:4px}

/* bottom nav */
.bottom-nav{display:flex;border-top:0.5px solid var(--border);background:var(--bg);position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:390px;z-index:10}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:10px 4px 8px;border:none;background:none;cursor:pointer;color:var(--text3);font-size:10px;font-weight:600}
.nav-btn.active{color:var(--text)}
.nav-btn i{font-size:22px}
</style>
</head>
<body>
<div class="app">

<div class="top-bar">
  <div class="top-bar-left">
    <span class="top-bar-title">🌾 サイレージ在庫</span>
    <div class="farm-switcher" onclick="openFarmSheet()">
      <span class="farm-name" id="current-farm-name"><i class="ti ti-building-farm"></i> 農場を選択</span>
      <i class="ti ti-chevron-down" style="font-size:14px;color:var(--text3)"></i>
    </div>
  </div>
  <span class="top-bar-date" id="today-lbl"></span>
</div>

<!-- ===== HOME ===== -->
<div id="page-home" class="page active">
  <div id="no-farm-msg" style="text-align:center;padding:3rem 1rem;color:var(--text3);font-size:13px;display:none">
    <i class="ti ti-building-farm" style="font-size:40px;display:block;margin-bottom:12px;color:var(--text3)"></i>
    農場を選択または追加してください
    <br><br>
    <button class="btn btn-primary" style="display:inline-block;flex:0;width:auto;padding:12px 24px" onclick="openFarmSheet()">農場を選択</button>
  </div>
  <div id="home-content">
    <div class="sec-lbl">在庫日数予測</div>
    <div id="forecast-gs"></div>
    <div id="forecast-dcs"></div>
    <div class="sec-lbl">種類別在庫</div>
    <div id="species-cards"></div>
    <div class="sec-lbl">貯蔵方法別在庫</div>
    <div id="home-storage"></div>
  </div>
</div>

<!-- ===== LIVESTOCK ===== -->
<div id="page-livestock" class="page">
  <div class="sec-lbl">月別 給与計画（12か月）</div>
  <p style="font-size:12px;color:var(--text2);margin-bottom:4px">給与量は<strong>現物（生重量）ベース</strong>で入力してください。農場ごとに保存されます。</p>

  <!-- silage type tab selector -->
  <div class="seg" id="lv-seg" style="margin-top:10px">
    <button class="seg-btn active" onclick="selectLvType('gs1',0)">GS1</button>
    <button class="seg-btn" onclick="selectLvType('gs2',1)">GS2</button>
    <button class="seg-btn" onclick="selectLvType('gs3',2)">GS3</button>
    <button class="seg-btn" onclick="selectLvType('dcs',3)">DCS</button>
  </div>

  <!-- GS1 -->
  <div id="lv-panel-gs1">
    <div style="background:#EAF3DE;border-radius:var(--radius-lg) var(--radius-lg) 0 0;padding:8px 12px;font-size:12px;font-weight:700;color:#27500A;margin-bottom:0">🌿 GS1（1番草）— 月別頭数・給与量</div>
    <div id="lv-table-gs1" style="overflow-x:auto;border:0.5px solid var(--border);border-top:none;border-radius:0 0 var(--radius-lg) var(--radius-lg);margin-bottom:10px"></div>
    <div class="result-box" id="lv-gs1-result" style="display:none"></div>
  </div>
  <!-- GS2 -->
  <div id="lv-panel-gs2" style="display:none">
    <div style="background:#C0DD97;border-radius:var(--radius-lg) var(--radius-lg) 0 0;padding:8px 12px;font-size:12px;font-weight:700;color:#27500A;margin-bottom:0">🌿 GS2（2番草）— 月別頭数・給与量</div>
    <div id="lv-table-gs2" style="overflow-x:auto;border:0.5px solid var(--border);border-top:none;border-radius:0 0 var(--radius-lg) var(--radius-lg);margin-bottom:10px"></div>
    <div class="result-box" id="lv-gs2-result" style="display:none"></div>
  </div>
  <!-- GS3 -->
  <div id="lv-panel-gs3" style="display:none">
    <div style="background:#97C459;border-radius:var(--radius-lg) var(--radius-lg) 0 0;padding:8px 12px;font-size:12px;font-weight:700;color:#173404;margin-bottom:0">🌿 GS3（3番草）— 月別頭数・給与量</div>
    <div id="lv-table-gs3" style="overflow-x:auto;border:0.5px solid var(--border);border-top:none;border-radius:0 0 var(--radius-lg) var(--radius-lg);margin-bottom:10px"></div>
    <div class="result-box" id="lv-gs3-result" style="display:none"></div>
  </div>
  <!-- DCS -->
  <div id="lv-panel-dcs" style="display:none">
    <div style="background:var(--blue-bg);border-radius:var(--radius-lg) var(--radius-lg) 0 0;padding:8px 12px;font-size:12px;font-weight:700;color:var(--blue-text);margin-bottom:0">🌽 DCS（デントコーン）— 月別頭数・給与量</div>
    <div id="lv-table-dcs" style="overflow-x:auto;border:0.5px solid var(--border);border-top:none;border-radius:0 0 var(--radius-lg) var(--radius-lg);margin-bottom:10px"></div>
    <div class="result-box" id="lv-dcs-result" style="display:none"></div>
  </div>

  <div class="btn-row" style="margin-bottom:8px">
    <button class="btn btn-primary" onclick="saveLivestock()">💾 保存する</button>
  </div>
  <div id="lv-msg" class="success-msg"></div>
</div>

<!-- ===== VISIT ===== -->
<div id="page-visit" class="page">
  <div class="sec-lbl">訪問日記録を追加</div>
  <div class="form-block"><label>訪問日</label><input type="date" id="vis-date"></div>
  <div class="form-block"><label>対象貯蔵庫</label><select id="vis-silo"></select></div>
  <div id="vis-fields"></div>
  <div id="vis-calc-result" class="result-box" style="display:none"></div>
  <div class="form-block"><label>メモ</label><input type="text" id="vis-note" placeholder="気になる点・品質など"></div>
  <div id="vis-msg" class="success-msg"></div>
  <div class="btn-row">
    <button class="btn" onclick="calcVisit()">計算</button>
    <button class="btn btn-primary" onclick="saveVisit()">記録する</button>
  </div>
  <div class="sec-lbl" style="margin-top:20px">訪問記録履歴</div>
  <div id="visit-history"></div>
</div>

<!-- ===== ADD ===== -->
<div id="page-add" class="page">
  <div class="sec-lbl">貯蔵方法を選択</div>
  <div class="seg">
    <button class="seg-btn active" onclick="selectType('banker',0)">バンカー</button>
    <button class="seg-btn" onclick="selectType('stack',1)">スタック</button>
    <button class="seg-btn" onclick="selectType('wrap',2)">コンビラップ</button>
  </div>
  <div id="form-banker">
    <div class="form-block"><label>名称</label><input id="bk-name" placeholder="バンカーサイロ #1" type="text"></div>
    <div class="form-block"><label>サイレージ種類</label><select id="bk-silage" onchange="toggleVarietyBlock('bk')">
      <option value="GS1">GS1（1番草）</option><option value="GS2">GS2（2番草）</option>
      <option value="GS3">GS3（3番草）</option><option value="DCS">DCS（デントコーン）</option>
      <option value="sorghum">ソルガム</option>
    </select></div>
    <div class="form-block" id="bk-variety-block" style="display:none"><label>品種の生育日数（日）</label>
      <input type="number" id="bk-variety-days" inputmode="numeric" placeholder="例: 120">
    </div>
    <div class="form-block"><label>草種</label><select id="bk-grass">
      <option value="">— 選択してください —</option>
      <option value="orchard">オーチャード</option>
      <option value="timothy">チモシー</option>
      <option value="orch_tim">オーチャード＋チモシー</option>
      <option value="orch_leg">オーチャード＋マメ科</option>
      <option value="tim_leg">チモシー＋マメ科</option>
    </select></div>
    <div class="form-row-2">
      <div class="form-block"><label>播種日</label><input type="date" id="bk-seeded" onchange="calcDays('bk')"></div>
      <div class="form-block"><label>刈り取り日</label><input type="date" id="bk-harvest" onchange="calcDays('bk')"></div>
    </div>
    <div class="form-block">
      <label>生育日数（刈り取り日 − 播種日）</label>
      <div id="bk-growdays" style="padding:10px 12px;background:var(--bg2);border-radius:var(--radius);font-size:14px;font-weight:700;color:var(--teal)">—</div>
    </div>
    <div class="form-row-2">
      <div class="form-block"><label>開封日</label><input type="date" id="bk-opened" onchange="calcDays('bk')"></div>
      <div class="form-block"><label>貯蔵日数（開封日 − 刈り取り日）</label>
        <div id="bk-storedays" style="padding:10px 12px;background:var(--bg2);border-radius:var(--radius);font-size:14px;font-weight:700;color:var(--purple-text)">—</div>
      </div>
    </div>
    <div class="form-row-2">
      <div class="form-block"><label>横 (m)</label><input type="number" id="bk-width" inputmode="decimal" placeholder="8"></div>
      <div class="form-block"><label>高さ (m)</label><input type="number" id="bk-h" inputmode="decimal" placeholder="2.5"></div>
    </div>
    <div class="form-row-2">
      <div class="form-block"><label>1パネル長さ (m)</label><input type="number" id="bk-plen" inputmode="decimal" placeholder="3"></div>
      <div class="form-block"><label>総パネル枚数</label><input type="number" id="bk-panels" inputmode="numeric" placeholder="20"></div>
    </div>
    <div class="form-block"><label>充填品質プリセット</label>
      <select id="bk-quality" onchange="applyDensity('bk')">
        <option value="">手動入力</option>
        <option value="260">DCS 非常に良い（260 kgDM/m³）</option>
        <option value="240">DCS 良い / GS 非常に良い（240）</option>

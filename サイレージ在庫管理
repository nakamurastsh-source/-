<script>
const SK_FARMS='silage_farms_v4';
const SK_DATA='silage_data_v4';

let farms=[];   // [{id,name,note}]
let allData={};  // {farmId:{silos:[],lv:{},visits:[]}}
let currentFarmId=null;

function load(){
  try{farms=JSON.parse(localStorage.getItem(SK_FARMS)||'[]');}catch(e){farms=[];}
  try{allData=JSON.parse(localStorage.getItem(SK_DATA)||'{}');}catch(e){allData={};}
  currentFarmId=localStorage.getItem('silage_current_farm')||null;
  if(currentFarmId&&!farms.find(f=>f.id==currentFarmId))currentFarmId=null;
}
function persist(){
  localStorage.setItem(SK_FARMS,JSON.stringify(farms));
  localStorage.setItem(SK_DATA,JSON.stringify(allData));
  if(currentFarmId)localStorage.setItem('silage_current_farm',currentFarmId);
}
function farmData(fid){
  fid=fid||currentFarmId;
  if(!fid)return{silos:[],lv:{},visits:[]};
  if(!allData[fid])allData[fid]={silos:[],lv:{},visits:[]};
  return allData[fid];
}
function silos(){return farmData().silos||[];}
function lv(){return farmData().lv||{};}
function visits(){return farmData().visits||[];}

function fmt(v,d){return(isNaN(v)||!isFinite(v))?'—':v.toFixed(d);}
function fmtN(v){return isNaN(v)||!isFinite(v)?'—':Math.round(v).toLocaleString();}
function isGS(s){return['GS1','GS2','GS3','sorghum'].includes(s);}
const TYPE_META={banker:{label:'バンカーサイロ',cls:'banker'},stack:{label:'スタックサイロ',cls:'stack'},wrap:{label:'コンビラップ',cls:'wrap'}};

/* ---- farm management ---- */
function openFarmSheet(){
  renderFarmList();
  document.getElementById('farm-sheet').classList.add('open');
}
function closeFarmSheet(){document.getElementById('farm-sheet').classList.remove('open');}

function renderFarmList(){
  const el=document.getElementById('farm-list');
  if(!farms.length){el.innerHTML='<div class="empty-sub">農場がまだ登録されていません</div>';return;}
  el.innerHTML=farms.map(f=>`
    <div class="farm-card${f.id==currentFarmId?' selected':''}" onclick="selectFarm('${f.id}')">
      <div class="farm-icon"><i class="ti ti-building-farm"></i></div>
      <div class="farm-info">
        <div class="farm-info-name" id="farm-label-${f.id}">${f.name}</div>
        <div class="farm-info-sub">${f.note||'メモなし'} · 貯蔵庫${(farmData(f.id).silos||[]).length}基</div>
      </div>
      ${f.id==currentFarmId?'<i class="ti ti-check" style="color:var(--teal);font-size:18px"></i>':''}
      <button onclick="event.stopPropagation();openFarmEdit('${f.id}')" style="border:none;background:none;color:var(--text2);font-size:18px;cursor:pointer;padding:4px"><i class="ti ti-edit"></i></button>
      <button onclick="event.stopPropagation();deleteFarm('${f.id}')" style="border:none;background:none;color:#c0392b;font-size:18px;cursor:pointer;padding:4px"><i class="ti ti-trash"></i></button>
    </div>`).join('');
}

function addFarm(){
  const name=document.getElementById('new-farm-name').value.trim();
  if(!name){document.getElementById('farm-msg').textContent='農場名を入力してください';return;}
  const id='f'+Date.now();
  farms.push({id,name,note:document.getElementById('new-farm-note').value.trim()});
  allData[id]={silos:[],lv:{},visits:[]};
  persist();
  document.getElementById('new-farm-name').value='';
  document.getElementById('new-farm-note').value='';
  document.getElementById('farm-msg').textContent='追加しました ✓';
  setTimeout(()=>document.getElementById('farm-msg').textContent='',2000);
  renderFarmList();
}

function selectFarm(id){
  currentFarmId=id;
  persist();
  const f=farms.find(x=>x.id===id);
  document.getElementById('current-farm-name').innerHTML=`<i class="ti ti-building-farm"></i> ${f.name}`;
  closeFarmSheet();
  renderHome();
}

function deleteFarm(id){
  if(!confirm('この農場と全データを削除しますか？'))return;
  farms=farms.filter(f=>f.id!==id);
  delete allData[id];
  if(currentFarmId===id){currentFarmId=null;document.getElementById('current-farm-name').innerHTML='<i class="ti ti-building-farm"></i> 農場を選択';}
  persist();
  renderFarmList();
  renderHome();
}

/* ---- navigation ---- */
function showPage(p,i){
  document.querySelectorAll('.page').forEach(el=>el.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach((el,j)=>el.classList.toggle('active',j===i));
  if(p==='home')renderHome();
  if(p==='list')renderList();
  if(p==='visit')renderVisitPage();
  if(p==='livestock')fillLivestockForm();
}
function selectType(t,i){
  ['banker','stack','wrap'].forEach((n,j)=>document.getElementById('form-'+n).style.display=j===i?'block':'none');
  document.querySelectorAll('.seg-btn').forEach((el,j)=>el.classList.toggle('active',j===i));
}
function applyDensity(pfx){const v=document.getElementById(pfx+'-quality').value;if(v)document.getElementById(pfx+'-density').value=v;}

/* ---- silo calculations ---- */
function calcBK(){
  const w=+document.getElementById('bk-width').value||0,h=+document.getElementById('bk-h').value||0;
  const plen=+document.getElementById('bk-plen').value||0,panels=+document.getElementById('bk-panels').value||0;
  const den=+document.getElementById('bk-density').value||0,dm=+document.getElementById('bk-dm').value||0;
  const loss=+document.getElementById('bk-loss').value||0,vol=plen*panels*w*h;
  const dmKg=vol*den,actKg=dm>0?dmKg/(dm/100):0;
  return{vol,dmKg,actKg,netDM:dmKg*(1-loss/100),netAct:actKg*(1-loss/100),dm,loss,plen,panels,w,h,den};
}
function calcST(){
  const tw=+document.getElementById('st-tw').value||0,bw=+document.getElementById('st-bw').value||0;
  const h=+document.getElementById('st-h').value||0,len=+document.getElementById('st-len').value||0;
  const coef=+document.getElementById('st-coef').value||0.8,den=+document.getElementById('st-density').value||0;
  const dm=+document.getElementById('st-dm').value||0,loss=+document.getElementById('st-loss').value||0;
  const vol=(tw+bw)/2*h*len*coef,dmKg=vol*den,actKg=dm>0?dmKg/(dm/100):0;
  return{vol,dmKg,actKg,netDM:dmKg*(1-loss/100),netAct:actKg*(1-loss/100),dm,loss,tw,bw,h,len,coef,den};
}
function calcWR(){
  const wt=+document.getElementById('wr-wt').value||0,cnt=+document.getElementById('wr-count').value||0;
  const dm=+document.getElementById('wr-dm').value||0,loss=+document.getElementById('wr-loss').value||0;
  const actKg=wt*cnt,dmKg=actKg*(dm/100);
  return{actKg,dmKg,netAct:actKg*(1-loss/100),netDM:dmKg*(1-loss/100),perDM:cnt>0?dmKg/cnt:0,dm,loss,wt,cnt};
}
function resultHTML(r,isWrap){
  if(isWrap)return`<div class="res-row"><span class="rl">合計現物（ロス前）</span><span class="rv">${fmt(r.actKg/1000,2)} t</span></div>
    <div class="res-row"><span class="rl">1個あたり乾物量</span><span class="rv">${fmt(r.perDM,1)} kgDM</span></div>
    <hr class="divider">
    <div class="res-row"><span class="rl">現物（ロス差引）</span><span class="rv hi">${fmt(r.netAct/1000,2)} t</span></div>
    <div class="res-row"><span class="rl">乾物（ロス差引）</span><span class="rv hi">${fmt(r.netDM/1000,2)} t DM</span></div>`;
  return`<div class="res-row"><span class="rl">容積</span><span class="rv">${fmt(r.vol,1)} m³</span></div>
    <div class="res-row"><span class="rl">乾物（ロス前）</span><span class="rv">${fmt(r.dmKg/1000,2)} t DM</span></div>
    <div class="res-row"><span class="rl">現物（ロス前）</span><span class="rv">${fmt(r.actKg/1000,2)} t</span></div>
    <hr class="divider">
    <div class="res-row"><span class="rl">現物（ロス差引）</span><span class="rv hi">${fmt(r.netAct/1000,2)} t</span></div>
    <div class="res-row"><span class="rl">乾物（ロス差引）</span><span class="rv hi">${fmt(r.netDM/1000,2)} t DM</span></div>`;
}
function calcForm(pfx){
  const r=pfx==='bk'?calcBK():pfx==='st'?calcST():calcWR();
  const el=document.getElementById(pfx+'-result');
  el.style.display='block';el.innerHTML=resultHTML(r,pfx==='wr');return r;
}
/* ---- date day calculators ---- */
function diffDays(d1,d2){
  if(!d1||!d2)return null;
  const ms=new Date(d2)-new Date(d1);
  return Math.round(ms/86400000);
}
function calcDays(pfx){
  const seeded=document.getElementById(pfx+'-seeded')?.value||'';
  const harvest=document.getElementById(pfx+'-harvest')?.value||'';
  const opened=document.getElementById(pfx+'-opened')?.value||'';
  const grow=diffDays(seeded,harvest);
  const store=diffDays(harvest,opened);

// onchange: 入力確定後にコピー判定。他の月が全部空なら全月に同じ値をセット
function onLvChange(pfx,changedMi,field,value){
  if(value==='')return;
  const order=lvMonthOrder();
  const firstMi=order[0]; // 今月 = テーブルの先頭行
  // 今月（先頭行）を変更した場合は、残り11か月を常に上書きコピー
  if(changedMi===firstMi){
    order.slice(1).forEach(mi=>{
      const el=document.getElementById('lv-'+pfx+'-'+mi+'-'+field);
      if(el){
        el.value=value;
        updateLvDaily(pfx,mi);
      }
    });
  }
  updateLvDaily(pfx,changedMi);
}


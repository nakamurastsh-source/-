// Returns kg/day for a silage type in a given month (0-based)
function getDailyForMonth(silageType, monthIdx){
  const l=lv();
  const pfx=silageType==='DCS'?'dcs':silageType==='GS2'?'gs2':silageType==='GS3'?'gs3':'gs1';
  const rows=l['monthly_'+pfx];
  if(!rows||!rows[monthIdx])return 0;
  const r=rows[monthIdx];
  return(r.mh||0)*(r.ma||0)+(r.dh||0)*(r.da||0);
}

// Returns total kg consumed from today until stock runs out, using monthly schedule
// Returns {days, endDate} 
function calcDaysRemaining(silageType, stockKg){
  if(stockKg<=0)return{days:0,endDate:null};
  const today=new Date();
  let remaining=stockKg;
  let days=0;
  const maxDays=366;
  for(let d=0;d<maxDays;d++){
    const date=new Date(today);date.setDate(today.getDate()+d);
    const mi=date.getMonth();
    const daily=getDailyForMonth(silageType,mi);
    if(daily<=0){days=d;break;}// no plan = stop counting
    remaining-=daily;
    if(remaining<=0){days=d+1+(remaining/daily);break;}
    days=d+1;
  }
  const endDate=new Date(today);endDate.setDate(today.getDate()+Math.floor(days));
  return{days:Math.floor(days),endDate};
}

// For home forecast: GS total (GS1+GS2+GS3 combined) vs DCS
function getDailyFromLVGroup(group){
  const mi=new Date().getMonth();
  if(group==='dcs')return getDailyForMonth('DCS',mi);
  return getDailyForMonth('GS1',mi)+getDailyForMonth('GS2',mi)+getDailyForMonth('GS3',mi);
}
function getDailyFromLV(silageType){
  return getDailyForMonth(silageType,new Date().getMonth());
}

